# Application Environment
# development | production
NODE_ENV=development

# JWT Configuration
# IMPORTANT: Use a strong random string (min 32 characters) for production
JWT_SECRET=your-secret-key-at-least-32-characters-long-for-production

# PostgreSQL Database
# For Docker: use 'postgres' as DB_HOST when running in same network
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=concentrate-quiz

# Redis Cache
# For Docker: use 'redis://redis:6379' when running in same network
REDIS_URL=redis://localhost:6379

# Google OAuth (optional, leave blank to disable OAuth)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# For production, update this to your actual domain
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Production Deployment Notes
# ============================
# When deploying with Docker:
# 1. All environment variables must be passed at container runtime
# 2. Use strong, securely-generated values for JWT_SECRET
# 3. Point DB_HOST and REDIS_URL to your external services or use docker-compose networking
# 4. Keep these variables in a secrets manager (not in git or source code)
